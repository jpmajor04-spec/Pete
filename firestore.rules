rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — anyone authenticated can read profiles (leaderboard, friends)
    // Owner can write their own doc fully; any authenticated user can update
    // only the friendIds field (needed when accepting a friend request)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friendIds']);
    }

    // Battles — any authenticated user can create or read
    // Only creator or opponent can update
    match /battles/{battleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.creator ||
        request.auth.uid == resource.data.opponent
      );
    }

    // Friend requests — sender or receiver can read
    // Only sender can create; either party can update/delete
    // Uses 'from' and 'to' field names (not fromId/toId)
    match /friend_requests/{reqId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.from ||
        request.auth.uid == resource.data.to
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.from;
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.from ||
        request.auth.uid == resource.data.to
      );
    }

    // Five-star sentences — anyone authenticated can read
    // Users can only write to their own entries
    match /five_stars/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Tournaments — any authenticated user can read or create
    // Only players in the tournament can update (submit scores, status changes)
    match /tournaments/{tournId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.playerIds ||
        request.auth.uid == resource.data.creatorId
      );

      // Tournament round entries — players can read all, write only their own
      match /entries/{entryId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == request.resource.data.uid;
      }
    }
  }
}
